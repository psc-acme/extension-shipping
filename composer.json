{
    "name": "psc-acme/extension-shipping",
    "description": "Package extension-shipping for psc-acme organization",
    "type": "project",
    "license": "MIT",
    "authors": [
        {
            "name": "Philipp Scheit",
            "email": "p.scheit@packagist.com"
        }
    ],
    "autoload": {
        "psr-4": {
            "PscAcme\\ExtensionShipping\\": "src/"
        }
    },
    "require": {
        "php": ">=8.3",
        "vlucas/phpdotenv": "^5.0",
        "symfony/lock": "^7.0",
        "illuminate/support": "^11.0",
        "symfony/cache": "^7.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.5",
        "phpstan/phpstan": "^1.0",
        "friendsofphp/php-cs-fixer": "^3.0"
    },
    "minimum-stability": "stable",
    "config": {
        "secure-http": false
    },
    "repositories": {
        "private-packagist": {
            "type": "composer",
            "url": "http://repo.packagist.com.lo/psc-acme/"
        },
        "packagist.org": false
    }
}